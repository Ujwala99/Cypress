{
    "compilerOptions": {
        "target":"ES2020",
        "lib":["ES2020","DOM"],
        "types":["cypress","node"],
        "strict": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "paths": {
            "@pages/*":["./pages/*"]
        },
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0"
    },
    "include":["**/*.ts"]
}